DEEPSEEK_API_KEY=your_deepseek_key
GLM_API_KEY=your_glm_key

# Decision Mode: "AI" or "RULE_BASED"
# RULE_BASED is faster, more reliable, and has zero API cost
DECISION_MODE=AI

# Active AI Provider: "DEEPSEEK" or "GLM" (only used when DECISION_MODE=AI)
ACTIVE_AI=GLM

# Risk Management
MAX_DAILY_LOSS_USD=50
MAGIC_NUMBER=100100

# Trailing Stop Configuration
TRAILING_MIN_PROFIT_ATR=0.5
TRAILING_DISTANCE_ATR=0.4

# Worker Intervals
BAR_WATCHER_POLL_S=1.0
TRAILING_INTERVAL_S=2.0